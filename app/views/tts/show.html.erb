<!-- Header -->
<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h1 class="h3">
        <i class="fas fa-file-audio text-primary me-2"></i>
        TTS Request #<%= @speech_request.id %>
      </h1>
      
      <div class="d-flex gap-2" role="group">
        <%= link_to "← Yeni İstek", root_path, class: "btn btn-outline-secondary" %>
        
        <% if @speech_request.status.in?(%w[pending processing]) %>
          <%= button_to "İptal Et", cancel_speech_request_path(@speech_request), 
              method: :patch,
              class: "btn btn-warning",
              data: { 
                confirm: "Bu işlemi iptal etmek istediğinizden emin misiniz?",
                bs_toggle: "tooltip",
                bs_title: "Bekleyen job'ları iptal eder"
              } %>
        <% end %>
        
        <% if @speech_request.status.in?(%w[failed partial cancelled]) %>
          <%= button_to "Tekrar Dene", retry_speech_request_path(@speech_request), 
              method: :patch,
              class: "btn btn-success",
              data: { 
                bs_toggle: "tooltip",
                bs_title: "Başarısız provider'ları tekrar çalıştırır"
              } %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Status Overview -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="row">
          <div class="col-md-3">
            <h6 class="text-muted mb-1">Durum</h6>
            <% case @speech_request.status %>
            <% when 'pending' %>
              <span class="badge bg-secondary fs-6">
                <i class="fas fa-clock me-1"></i>Bekliyor
              </span>
            <% when 'processing' %>
              <span class="badge bg-warning fs-6">
                <i class="fas fa-spinner fa-spin me-1"></i>İşleniyor
              </span>
            <% when 'partial' %>
              <span class="badge bg-info fs-6">
                <i class="fas fa-exclamation-triangle me-1"></i>Kısmi Başarı
              </span>
            <% when 'completed' %>
              <span class="badge bg-success fs-6">
                <i class="fas fa-check-circle me-1"></i>Tamamlandı
              </span>
            <% when 'failed' %>
              <span class="badge bg-danger fs-6">
                <i class="fas fa-times-circle me-1"></i>Başarısız
              </span>
            <% when 'cancelled' %>
              <span class="badge bg-secondary fs-6">
                <i class="fas fa-ban me-1"></i>İptal Edildi
              </span>
            <% end %>
          </div>
          <div class="col-md-3">
            <h6 class="text-muted mb-1">Başarılı Provider</h6>
            <strong><%= @speech_request.successful_results.size %>/3</strong>
          </div>
          <div class="col-md-3">
            <h6 class="text-muted mb-1">Oluşturulma</h6>
            <small><%= @speech_request.created_at.strftime("%d.%m.%Y %H:%M") %></small>
          </div>
          <div class="col-md-3">
            <h6 class="text-muted mb-1">Hash</h6>
            <small class="font-monospace"><%= @speech_request.text_hash[0..8] %>...</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Original Text -->
<div class="row mb-4">
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">
          <i class="fas fa-file-text me-2"></i>Orijinal Metin
        </h5>
      </div>
      <div class="card-body">
        <div class="bg-light p-3 rounded">
          <%= simple_format(@speech_request.text) %>
        </div>
        <small class="text-muted">
          <i class="fas fa-info-circle me-1"></i>
          <%= @speech_request.text.length %> karakter
        </small>
      </div>
    </div>
  </div>
</div>

<!-- Provider Results -->
<div class="row">
  <div class="col-12">
    <h4 class="mb-3">
      <i class="fas fa-cloud me-2"></i>Provider Sonuçları
    </h4>
  </div>
  
  <% %w[resemble elevenlabs openai].each_with_index do |provider, index| %>
    <% result = @speech_request.provider_result_for(provider) %>
    <% colors = %w[success info warning] %>
    <% color = colors[index] %>
    
    <div class="col-md-4 mb-4">
      <div class="card h-100 border-<%= color %>">
        <div class="card-header bg-<%= color %> text-white">
          <h6 class="card-title mb-0">
            <% case provider %>
            <% when 'resemble' %>
              <i class="fas fa-robot me-2"></i>Resemble AI
            <% when 'elevenlabs' %>
              <i class="fas fa-brain me-2"></i>ElevenLabs
            <% when 'openai' %>
              <i class="fas fa-lightning-bolt me-2"></i>OpenAI
            <% end %>
          </h6>
        </div>
        <div class="card-body">
          <% if result %>
            <% if result['status'] == 'completed' %>
              <!-- Success -->
              <div class="text-center mb-3">
                <i class="fas fa-check-circle text-success" style="font-size: 2rem;"></i>
                <p class="text-success mb-0 fw-bold">Başarılı</p>
              </div>
              
              <div class="mb-3">
                <small class="text-muted d-block">Dosya Bilgileri:</small>
                <ul class="list-unstyled small">
                  <li><strong>Format:</strong> <%= result['format']&.upcase %></li>
                  <li><strong>Boyut:</strong> <%= number_to_human_size(result['size']) if result['size'] %></li>
                  <li><strong>Süre:</strong> <%= result['duration'] %>s</li>
                  <li><strong>Oluşturulma:</strong> <%= Time.parse(result['generated_at']).strftime("%H:%M") rescue 'N/A' %></li>
                </ul>
              </div>
              
              <div class="d-grid">
                <%= link_to speech_request_download_path(@speech_request, provider), 
                    class: "btn btn-#{color} btn-sm",
                    data: { 
                      bs_toggle: "tooltip",
                      bs_title: "Presigned URL ile güvenli indirme"
                    } do %>
                  <i class="fas fa-download me-1"></i>İndir
                <% end %>
              </div>
              
            <% elsif result['status'] == 'failed' %>
              <!-- Failed -->
              <div class="text-center mb-3">
                <i class="fas fa-times-circle text-danger" style="font-size: 2rem;"></i>
                <p class="text-danger mb-0 fw-bold">Başarısız</p>
              </div>
              
              <div class="alert alert-danger" role="alert">
                <small>
                  <strong>Hata:</strong><br>
                  <%= result['error_message'] %>
                </small>
              </div>
              
            <% else %>
              <!-- Processing -->
              <div class="text-center mb-3">
                <i class="fas fa-spinner fa-spin text-warning" style="font-size: 2rem;"></i>
                <p class="text-warning mb-0 fw-bold">İşleniyor</p>
              </div>
            <% end %>
            
          <% else %>
            <!-- Pending -->
            <div class="text-center mb-3">
              <i class="fas fa-clock text-muted" style="font-size: 2rem;"></i>
              <p class="text-muted mb-0 fw-bold">Bekliyor</p>
            </div>
            <p class="text-muted small text-center">
              Bu provider henüz işleme alınmadı.
            </p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Auto Refresh for Processing -->
<% if @speech_request.status.in?(%w[pending processing]) %>
  <div class="row mt-4">
    <div class="col-12">
      <div class="alert alert-info" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <strong>İşlem devam ediyor.</strong> Sayfa 10 saniyede bir otomatik yenilenecek.
      </div>
    </div>
  </div>
  
  <script>
    // Auto-refresh every 10 seconds if still processing
    setTimeout(function() {
      window.location.reload();
    }, 10000);
  </script>
<% end %>

<!-- Debug Info (Development Only) -->
<% if Rails.env.development? %>
  <div class="row mt-5">
    <div class="col-12">
      <details>
        <summary class="text-muted">Debug Bilgileri (Development)</summary>
        <pre class="mt-2 p-3 bg-light rounded small"><%= JSON.pretty_generate(@speech_request.provider_results) %></pre>
      </details>
    </div>
  </div>
<% end %>
